# Local admin/developer secrets for direct R2 and Supabase maintenance only.
# Do not commit real values. Do not ship this file in desktop builds.
# Normal users do not need this file.
#
# Desktop runtime direct-R2 is opt-in via SPORELY_ENABLE_DIRECT_R2=1.
# Public media Worker URL lives in SPORELY_MEDIA_WORKER_URL (default https://upload.sporely.no).
# That value is public runtime config, not a secret, and does not belong in this file.

R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
SUPABASE_SERVICE_ROLE_KEY=replace-me
